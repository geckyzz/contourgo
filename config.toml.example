# ─── Discord Bot Integration ──────────────────────────────────────────────────
# Global settings for the Discord gateway, channel announcements, and pings:
#   token                      - Bot token used for Discord authentication (required)
#   server                     - Guild server ID target for hot command sync (optional)
#   - - - - - - - - - - - - - -
#   announce.channel           - Default channel ID where announcements are sent (required)
#   - - - - - - - - - - - - - -
#   mentions                   - Map of "@username" strings to Discord User snowflakes
#   mentions_disable           - Switch to disable all mentions and user pings globally (default: false)
#   - - - - - - - - - - - - - -
#   members.admins.allow       - Permit command access to server admins (default: true)
#   members.moderators.allow   - Permit command access to server managers (default: false)
#   members.others.allow       - Whitelist of user IDs permitted to run bot commands (default: [])
#   - - - - - - - - - - - - - -
#   embed.author.url           - Icon image URL displayed on announcement embeds (optional)
#   fields.comment_id          - Display the comment ID on tracker embeds (default: false)
#   display.user_content_image - Render image attachments in comment embeds (default: false)
#   - - - - - - - - - - - - - -
[discord]
token = "MTM....."
server = "1326230604295180423"
announce.channel = "1234567890"
mentions = { "geckyzz" = 123456789012345678 }
mentions_disable = false
members.admins.allow = true
members.moderators.allow = false
members.others.allow = []

# ─── Donation Management ────────────────────────────────────────────────────────
# Donation settings manage server roles, transaction logs, and notification DMs:
#   perk_multiplier   - Amount in USD per 1 month of active perk duration (default: 9.99)
#   max_stacks        - Maximum cumulative months of duration that can be queued (default: 12)
#   notify_warn_days  - Days remaining before expiration to send warning pings (0 to disable, default: 3)
#   silent.globally   - Disable all automated donator DM notifications (default: false)
#   silent.on_warning - Disable warnings sent prior to role expiration (default: false)
#   silent.on_expiry  - Disable final role expiration DM notices (default: false)
#   [donation.tiers]  - Multi-tier dynamic rewards mapping Role ID = Cumulative USD Threshold
#
[donation]
perk_multiplier = 9.99
max_stacks = 12
notify_warn_days = 3
silent.globally = false
silent.on_warning = false
silent.on_expiry = false

[donation.tiers]
"1326239425612611604" = 9.99
"1400000000000000000" = 50.00

# ┈-┈ Customizable DM Notification Templates ┈-┈
# Configure customized text values for direct messaging notifications:
#   Supported Placeholders:
#     - {{.Username}}        - Discord display username of the donator user
#     - {{.UserID}}          - Discord numeric snowflake ID of the donator user
#     - {{.Amount}}          - Formatted currency string added (e.g. "$9.99 USD")
#     - {{.AmountValue}}     - Raw float value of the current transaction amount
#     - {{.Cumulative}}      - Cumulative formatted donation total (e.g. "$19.98 USD")
#     - {{.CumulativeValue}} - Raw float value of cumulative donation total
#     - {{.Duration}}        - Formatted text representation of added time (e.g. "30 days")
#     - {{.Expiry}}          - Full human-readable target date string (e.g. "January 2, 2026")
#     - {{.ExpiryUnix}}      - Raw Unix epoch integer timestamp of the expiry date
#     - {{.TimeLeft}}        - Time left remaining (Only for Warning DMs)
#
[donation.format.add]
title = "💖 Donation Received & Perks Activated!"
desc = "Thank you so much for your support {{.Username}}! Your donation of {{.Amount}} has been recorded, and your perks are now active until <t:{{.ExpiryUnix}}:f> (<t:{{.ExpiryUnix}}:R>)."

[donation.format.renew]
title = "🔁 Perks Renewed & Subscription Extended!"
desc = "Thank you so much for renewing your support, {{.Username}}! We've extended your perks for another {{.Duration}}. Your new expiry date is <t:{{.ExpiryUnix}}:f> (<t:{{.ExpiryUnix}}:R>)."

[donation.format.warn]
title = "⚠️ Donator Perks Expiring Soon"
desc = "Your donator perks will expire on <t:{{.ExpiryUnix}}:f> (<t:{{.ExpiryUnix}}:R>). Renew your subscription to keep access!"

[donation.format.expiry]
title = "🔒 Donator Perks Expired"
desc = "Hello {{.Username}}, your donator role subscription expired at <t:{{.ExpiryUnix}}:f>, and your perks have been disabled. We want to thank you sincerely for supporting the cause!"


# ─── Scraper Engine Defaults ──────────────────────────────────────────────────
# Global values and scraper intervals used across active tracker monitors:
#   monitor.by              - Global poll cadence check frequency (default: "PT30M")
#   time.uniform            - Align scheduler runs to clean time divisions (default: false)
#   - - - - - - - - - - - - - -
#   nyaa.proxy.url          - Base URL to your nyaa-api-worker service (required)
#   nyaa.page.max           - Pages to scan on checking Nyaa (default: 0)
#   nyaa.sort               - Nyaa release search sorting field (default: "comments")
#   nyaa.order              - Nyaa sort direction (default: "desc")
#   - - - - - - - - - - - - - -
#   animetosho.old.page.max - Pages to check on animetosho_old (default: 5)
#   animetosho.new.page.max - Pages to check on animetosho_new (default: 5)
#   - - - - - - - - - - - - - -
#   nekobt.api.key          - Your nekoBT API/SSID auth key (optional)
#   nekobt.page.max         - Pages to check on nekoBT checks (default: 1)
#   nekobt.sort             - Sort mode on nekoBT queries (default: "date")
#   - - - - - - - - - - - - - -
#   anirena.api.key         - Your AniRena API credential key (optional)
#   anirena.page.max        - Pages to check on AniRena checks (default: 0)
#   anirena.sort            - Sort mode on AniRena queries (default: "date")
#   anirena.order           - Sort direction on AniRena checks (default: "desc")
#   - - - - - - - - - - - - - -
#   twitter.nitter_url      - Default Nitter instance base URL (default: "https://nitter.net")
#   twitter.embed_service   - Domain rewrite used to preview tweet links (default: "x.com")
#   twitter.exclude_reposts - Skip retweets matching RT format (default: false)
#
[config]
monitor.by = "PT30M"
time.uniform = false
nyaa.proxy.url = ""
nyaa.page.max = 0
nyaa.sort = "comments"
nyaa.order = "desc"
animetosho.old.page.max = 5
animetosho.new.page.max = 5
nekobt.api.key = ""
nekobt.page.max = 1
nekobt.sort = "date"
anirena.api.key = ""
anirena.page.max = 0
anirena.sort = "date"
anirena.order = "desc"
twitter.nitter_url = ""
twitter.embed_service = ""
twitter.exclude_reposts = false

# ─── Nyaa / Sukebei Tracker ────────────────────────────────────────────────────
# Nyaa/Sukebei monitors live under [monitor.nyaa.<key>] and [monitor.sukebei.<key>] and support:
#   keywords                 - List of query keywords to search (optional)
#   excludes                 - List of glob-like patterns to exclude by title (optional)
#   uploaders                - List of uploaders/users to filter by (optional)
#   sort                     - Sort method: comments, size, id, seeders, leechers, downloads (optional, defaults to config level or "comments")
#   order                    - Sort order: desc, asc (optional, defaults to config level or "desc")
#   page.max                 - Max number of search pages to parse (optional, defaults to config level or 0 for unlimited)
#
[monitor.nyaa.normies]
keywords = ["fansubs", "raws"]
uploaders = ["username1", "username2"]
sort = "comments"
order = "desc"
page.max = 0
discord.embed.author.url = "https://i.imgur.com/some-nyaa-image.png"
discord.mentions.disable = true
discord.fields.comment_id = false
discord.display.user_content_image = false

[monitor.sukebei.lewd]
uploaders = ["uploader_name"]
sort = "id"
order = "desc"
page.max = 0
discord.embed.author.url = "https://i.imgur.com/some-sukebei-image.png"

# ─── AnimeTosho (New & Old) ───────────────────────────────────────────────────
# AnimeTosho monitors live under [monitor.animetosho_new.<key>] and [monitor.animetosho_old.<key>] and support:
#   keywords        - List of query keywords to match (optional)
#   excludes        - List of glob-like patterns to exclude by title (optional)
#   page.max        - Max number of pages to parse (optional, defaults to config level)
#
[monitor.animetosho_new.all]
keywords = ["Gecko"]
page.max = 5
discord.embed.author.url = "https://i.imgur.com/some-at-new-image.png"

[monitor.animetosho_old.all]
keywords = ["Gecko", "geckyzz", "CicakRumah", "TokekHutan"]
page.max = 5
discord.embed.author.url = "https://i.imgur.com/some-at-image.png"

# ─── NekoBT ───────────────────────────────────────────────────────────────────
# NekoBT monitors live under [monitor.nekobt.<key>] and support:
#   groups          - List of target group IDs to filter by (optional)
#   uploaders       - List of target uploader IDs to filter by (optional)
#   media           - List of target media IDs (e.g. s123, tmdb:456, tvdb:789) (optional)
#   keywords        - List of query keywords to fallback search (optional)
#   excludes        - List of glob-like patterns to exclude by title (optional)
#   sort            - Sort method: best, latest, oldest, rss, seeders, downloads, comments, etc. (optional, defaults to config level or "date")
#   page.max        - Max number of pages to parse (optional, defaults to config level or 1)
#
[monitor.nekobt.my_group]
groups = ["12345"]
uploaders = ["67890"]
media = ["s123", "tmdb:456", "tvdb:789"]
keywords = ["some search term"]
sort = "comments"
discord.embed.author.url = "https://i.imgur.com/some-nekobt-image.png"

# ─── AniRena ──────────────────────────────────────────────────────────────────
# AniRena monitors live under [monitor.anirena.<key>] and support:
#   keywords        - List of query keywords to search (optional)
#   uploaders       - AniRena username to filter by (optional)
#   excludes        - List of glob-like patterns to exclude by title (optional)
#   sort            - Sort method: comments, size, id, seeders, leechers, downloads (optional, defaults to config level or "date")
#   order           - Sort order: desc, asc (optional, defaults to config level or "desc")
#   page.max        - Max number of pages to parse (optional, defaults to config level or 0 for unlimited)
#
[monitor.anirena.normies]
keywords = ["fansubs", "raws"]
uploaders = ["username1"]
sort = "comments"
order = "desc"
page.max = 0
discord.embed.author.url = "https://i.imgur.com/some-anirena-image.png"

# ─── Tsukihime ────────────────────────────────────────────────────────────────
# Tsukihime monitors live under [monitor.tsukihime.<key>] and support:
#   groups          - List of group IDs or group names (optional)
#   uploaders       - List of commenter/uploader user IDs or usernames (optional)
#   media           - List of series IDs (e.g. 79, mal:59970, anilist:ID, anidb:ID) (optional)
#   keywords        - List of search terms to filter by (optional)
#   excludes        - List of glob-like patterns to exclude by title (optional)
#   page.max        - Max number of pages to parse (optional, defaults to 1)
#
[monitor.tsukihime.my_group]
groups = ["16", "Gecko"]
uploaders = ["19", "TokekHutan"]
media = ["79", "mal:59970"]
keywords = ["Snowball Earth"]
page.max = 1
discord.embed.author.url = "https://i.imgur.com/some-tsukihime-image.png"

[monitor.tsukihime.feedback]
keywords = [
  "magnet",
  "DDL",
] # list of keywords to monitor general feedback comments
page.max = 1
discord.embed.author.url = "https://i.imgur.com/some-feedback-image.png"

# ─── Twitter / X via Nitter RSS ────────────────────────────────────────────────
# Twitter monitors live under [monitor.twitter.<key>] and support:
#   account         - Twitter username (optional, defaults to keyname)
#   keywords        - List of regex patterns to match against tweet title (optional)
#   excludes        - List of regex patterns to skip matching tweets (optional)
#   exclude_reposts - Ignore retweet/repost items (starts with "RT by @") (optional, boolean)
#   nitter_url      - Nitter base URL override (optional)
#   embed_service   - Embed domain rewrite for Discord preview.
#                     Valid short names: "fixupx", "vxtwitter", "fxtwitter", "twittpr", "fixvx"
#                     Or pass any custom bare domain: e.g., "fixvx.com" (defaults to x.com if empty)
#   custom_format   - Go template string content override (optional). Defaults to posting the tweet URL (rewritten via `embed_service` if configured, else the original twitter.com URL).
#                     Supported keys: {{.Account}}, {{.DisplayName}}, {{.TweetID}}, {{.Link}}, {{.OriginalLink}}, {{.Title}}, {{.PublishedAt}}
#
[monitor.twitter.mofusand_anime]
discord.channel = "1234567890123456789"
embed_service = "fixupx"
exclude_reposts = true
discord.mentions.disable = false
monitor.by = "PT15M"

[monitor.twitter.my_custom_account]
account = "realusername"
discord.channel = "9876543210987654321"
embed_service = "vxtwitter"
custom_format = "📢 New tweet by **@{{.Account}}**: {{.Link}}"
monitor.by = "PT30M"
